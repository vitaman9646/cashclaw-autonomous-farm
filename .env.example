# ============================================
# LLM API Configuration
# ============================================

# OpenRouter (recommended for cost efficiency)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
DEFAULT_PROVIDER=openrouter
DEFAULT_MODEL=anthropic/claude-sonnet-4

# Fallback providers (optional)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================
# Wallet Configuration
# ============================================

# Main wallet for withdrawals
MAIN_WALLET_ADDRESS=0xYourMainWalletAddress

# ============================================
# Monitoring & Notifications
# ============================================

# Telegram Bot (for reports and alerts)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# Dashboard
DASHBOARD_PORT=3777
DASHBOARD_ENABLED=true

# ============================================
# VPS Configuration (for deployment)
# ============================================

SERVER_IP=your_vps_ip_address
SSH_USER=root
SSH_PORT=22
SSH_KEY_PATH=~/.ssh/id_rsa

# ============================================
# Autonomous System Configuration
# ============================================

# Enable autonomous mode (set to false for manual control)
AUTONOMOUS_ENABLED=true

# Auto-scaling
AUTO_SCALING_ENABLED=true
MAX_AGENTS=50

# Auto-optimization
AUTO_OPTIMIZATION_ENABLED=true

# Auto-withdrawal
AUTO_WITHDRAWAL_ENABLED=true
WITHDRAWAL_THRESHOLD=0.1

# ============================================
# Safety & Limits
# ============================================

# Maximum daily API spend (USD)
MAX_DAILY_SPEND=20

# Emergency stop thresholds
EMERGENCY_STOP_ENABLED=true
MIN_WIN_RATE=20
MAX_LOSS_PER_DAY=0.1

# ============================================
# Advanced (optional)
# ============================================

# Node environment
NODE_ENV=production

# Log level
LOG_LEVEL=info

# API rate limits
OPENROUTER_RATE_LIMIT=100
